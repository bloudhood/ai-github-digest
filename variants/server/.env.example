# Copy this to /opt/github-digest/.env and fill secrets there.

EMAIL_FROM=digest@example.com
EMAIL_TO=recipient-primary@example.com,recipient-secondary@example.com
REPORT_TIMEZONE=Asia/Hong_Kong

# Final email size stays capped; the candidate/review pool can be wider on server deployments.
MAX_PROJECTS=10
GITHUB_SEARCH_PAGES=2
TRENDING_CANDIDATE_LIMIT=20
SEARCH_PLAN_CONCURRENCY=4
LOW_DELTA_QUALITY_FLOOR=34

DEEPSEEK_MODEL=deepseek-v4-flash
DIGEST_OVERVIEW_MODEL=deepseek-v4-pro
PROJECT_SUMMARY_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=enabled
DIGEST_OVERVIEW_REASONING_EFFORT=max
PROJECT_SUMMARY_REASONING_EFFORT=high

REPEAT_COOLDOWN_DAYS=5
REPEAT_WINDOW_DAYS=14
BREAKOUT_STAR_DELTA=120
JUYA_RSS_URL=https://daily.juya.uk/rss.xml
JUYA_CONTENT_LIMIT=30000

DIGEST_STATE_FILE=/opt/github-digest/data/state.json
DIGEST_LOG_DIR=/opt/github-digest/logs

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
GITHUB_TOKEN=
DEEPSEEK_API_KEY=
