{
  "name": "github-digest",
  "version": "1.0.0",
  "description": "AI / GitHub digest mailer with server and Cloudflare deployment variants",
  "main": "index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "node --check index.js",
    "cloudflare:deploy": "npx -y wrangler deploy --config variants/cloudflare-worker/wrangler.local.toml",
    "cloudflare:deploy:dry-run": "npx -y wrangler deploy --dry-run --config variants/cloudflare-worker/wrangler.local.toml",
    "cloudflare:dev": "npx -y wrangler dev --config variants/cloudflare-worker/wrangler.local.toml",
    "deploy": "npm run cloudflare:deploy",
    "deploy:dry-run": "npm run cloudflare:deploy:dry-run",
    "dev": "npm run cloudflare:dev",
    "node:dry-run": "node variants/server/scripts/run-node.mjs --dry-run",
    "node:send": "node variants/server/scripts/run-node.mjs --send",
    "tail": "npx -y wrangler tail",
    "test": "node --loader ./test/cloudflare-email-loader.mjs --test test/*.js"
  },
  "keywords": [
    "cloudflare-workers",
    "github-trending",
    "ai",
    "email-digest",
    "llm"
  ],
  "author": "bloudhood",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^4.94.0"
  }
}
